{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "signin.html",
          "dashboard.html",
          "styles.css",
          "script.js",
          "signin.js",
          "dashboard.js",
          "assets/**",
          "lib/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
